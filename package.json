{
    "name": "ropegeo-common",
    "version": "1.13.0",
    "description": "Shared domain models and helpers for RopeGeo and WebScraper",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/yurst3/RopeGeo-Common"
    },
    "type": "commonjs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./models": {
            "types": "./dist/models/index.d.ts",
            "default": "./dist/models/index.js"
        },
        "./helpers": {
            "types": "./dist/helpers/index.d.ts",
            "default": "./dist/helpers/index.js"
        },
        "./helpers/network": {
            "types": "./dist/helpers/network/index.d.ts",
            "default": "./dist/helpers/network/index.js"
        },
        "./components": {
            "types": "./dist/components/index.d.ts",
            "default": "./dist/components/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "test": "jest -i --no-watchman"
    },
    "peerDependencies": {
        "@aws-sdk/client-cloudfront": "^3.970.0",
        "@aws-sdk/client-s3": "^3.970.0",
        "@aws-sdk/client-sqs": "^3.970.0",
        "react": "^18.0.0 || ^19.0.0",
        "undici": "^7.0.0"
    },
    "devDependencies": {
        "@aws-sdk/client-cloudfront": "^3.971.0",
        "@aws-sdk/client-s3": "^3.971.0",
        "@aws-sdk/client-sqs": "^3.971.0",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.2.3",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.3.0",
        "react": "^19.1.0",
        "react-dom": "^19.2.4",
        "ts-jest": "^29.2.5",
        "typescript": "^5.9.3",
        "undici": "^7.11.0"
    },
    "files": [
        "dist"
    ]
}
