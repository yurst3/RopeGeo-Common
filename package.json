{
    "name": "ropegeo-common",
    "version": "1.8.1",
    "description": "Shared domain classes and helpers for RopeGeo and WebScraper",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/yurst3/RopeGeo-Common"
    },
    "type": "commonjs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./classes": {
            "types": "./dist/classes/index.d.ts",
            "default": "./dist/classes/index.js"
        },
        "./helpers": {
            "types": "./dist/helpers/index.d.ts",
            "default": "./dist/helpers/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "test": "jest -i --no-watchman"
    },
    "peerDependencies": {
        "@aws-sdk/client-cloudfront": "^3.970.0",
        "@aws-sdk/client-s3": "^3.970.0",
        "@aws-sdk/client-sqs": "^3.970.0",
        "undici": "^7.0.0"
    },
    "devDependencies": {
        "@aws-sdk/client-cloudfront": "^3.971.0",
        "@aws-sdk/client-s3": "^3.971.0",
        "@aws-sdk/client-sqs": "^3.971.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.9.3",
        "undici": "^7.11.0"
    },
    "files": [
        "dist"
    ]
}