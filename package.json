{
    "name": "ropegeo-common",
    "version": "1.6.0",
    "description": "Shared types and utilities for RopeGeo and WebScraper",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/yurst3/RopeGeo-Common"
    },
    "type": "commonjs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        },
        "./helpers": {
            "types": "./dist/helpers/index.d.ts",
            "default": "./dist/helpers/index.js"
        },
        "./helpers/*": {
            "types": "./dist/helpers/*.d.ts",
            "default": "./dist/helpers/*.js"
        },
        "./helpers/s3/*": {
            "types": "./dist/helpers/s3/*.d.ts",
            "default": "./dist/helpers/s3/*.js"
        },
        "./helpers/sqs/*": {
            "types": "./dist/helpers/sqs/*.d.ts",
            "default": "./dist/helpers/sqs/*.js"
        },
        "./helpers/cloudfront/*": {
            "types": "./dist/helpers/cloudfront/*.d.ts",
            "default": "./dist/helpers/cloudfront/*.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "test": "jest -i --no-watchman"
    },
    "peerDependencies": {
        "@aws-sdk/client-cloudfront": "^3.970.0",
        "@aws-sdk/client-s3": "^3.970.0",
        "@aws-sdk/client-sqs": "^3.970.0",
        "undici": "^7.0.0"
    },
    "devDependencies": {
        "@aws-sdk/client-cloudfront": "^3.971.0",
        "@aws-sdk/client-s3": "^3.971.0",
        "@aws-sdk/client-sqs": "^3.971.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.9.3",
        "undici": "^7.11.0"
    },
    "files": [
        "dist"
    ]
}